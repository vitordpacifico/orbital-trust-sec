<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Driver PostgreSQL — única dependência externa, restrita ao demo de banco -->
    <PackageReference Include="Npgsql" Version="8.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reaproveita a MESMA classe CryptoService (AES-256-GCM) do projeto principal,
         sem duplicar o algoritmo. Inclui só a classe, não o Program.cs do demo. -->
    <Compile Include="..\CryptoService\CryptoService.cs" Link="CryptoService.cs" />
  </ItemGroup>

</Project>
